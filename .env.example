# Sanity project ID/dataset/apiVersion are hardcoded in sanity.config.ts and
# src/lib/sanity.ts (public, non-secret identifiers) — not read from env.
# Read token (server-side build / SSG). Leave blank for public datasets.
SANITY_READ_TOKEN=

# AI-assisted translation (phase 6) — server-side only, never expose to the client
ANTHROPIC_API_KEY=
# Write token used by the translate worker to create JA/MY draft documents
SANITY_WRITE_TOKEN=
# Shared secret the Studio action sends and the translate worker checks
TRANSLATE_SHARED_SECRET=
# Baked into the Studio bundle at deploy time (SANITY_STUDIO_ env prefix)
SANITY_STUDIO_TRANSLATE_WORKER_URL=
SANITY_STUDIO_TRANSLATE_SECRET=
